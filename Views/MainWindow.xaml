<Window
    x:Class="Codec.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Codec.Models"
    xmlns:conv="using:Codec.Helpers"
    xmlns:views="using:Codec.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" MinWidth="420" MinHeight="520">
        <Grid.Resources>
            <conv:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <!-- Softer default blur overlay -->
            <AcrylicBrush x:Key="BlurOverlayBrush"
                          TintColor="#66000000"
                          TintOpacity="0.25"
                          TintLuminosityOpacity="0.8"
                          FallbackColor="#66000000" />
            <Style TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" x:Name="AppTitleBar" Height="48" Visibility="Collapsed" />

        <!-- Main content with sidebar and library/details area -->
        <Grid Grid.Row="1">
            <Grid ColumnSpacing="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="#191919" CornerRadius="12" Canvas.ZIndex="3">
                    <Grid RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Codec Library" FontSize="18" FontWeight="Bold" Margin="0,12,0,10" HorizontalAlignment="Center"/>

                        <ListView x:Name="SidebarGameList"
                                  Grid.Row="1"
                                  ItemsSource="{Binding Games}"
                                  SelectedItem="{Binding SidebarSelectedItem, Mode=TwoWay}"
                                  IsEnabled="{Binding IsUiEnabled}"
                                  SelectionMode="Single"
                                  SelectionChanged="SidebarGameList_SelectionChanged"
                                  BorderThickness="0"
                                  Background="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:Game">
                                    <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <StackPanel Grid.Row="2" Spacing="6" Margin="4,0,4,0">
                            <Button x:Name="SidebarDebugButton"
                                    Content="Debug"
                                    IsEnabled="{Binding IsUiEnabled}"
                                    HorizontalAlignment="Stretch"
                                    FontWeight="SemiBold">
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Debug Data" Click="Debug_Click" />
                                        <MenuFlyoutItem Text="Refresh Covers" Click="RefreshCovers_Click" />
                                        <MenuFlyoutItem Text="Reset App" Click="ResetApp_Click" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>

                            <Grid Height="150" Margin="0,0,0,8">
                                <Image Source="ms-appx:///Assets/shrimpSleep.png" Stretch="Uniform"/>
                                <Button x:Name="SidebarAddButton"
                                        Content="Add Games"
                                        IsEnabled="{Binding IsUiEnabled}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,105,4"
                                        Padding="12,6"
                                        FontSize="12"
                                        FontWeight="Medium"
                                        Background="#A0363636"
                                        BorderBrush="#A9363636">
                                    <Button.Flyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="Scan for Games" Click="SidebarAddGames_Click" />
                                            <MenuFlyoutItem Text="Add by Executable" Click="AddGame_Click" />
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Library grid UserControl -->
                <views:LibraryView Grid.Column="1"
                                   Margin="12,32,12,0"
                                   Visibility="{Binding IsLibraryGridVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Canvas.ZIndex="0"/>

                <!-- Game detail UserControl -->
                <views:GameDetailView Grid.Column="1"
                                      Visibility="{Binding IsDetailsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                      Canvas.ZIndex="1"/>
            </Grid>
        </Grid>

        <!-- Global app-level overlays -->
        <Grid Grid.RowSpan="2" Grid.ColumnSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="True">
            <StackPanel Visibility="{Binding IsScanProgressVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                        Background="#BF1C1C1C"
                        Padding="24"
                        CornerRadius="8"
                        Spacing="12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding ScanProgressMessage}"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           FontFamily="ms-appx:///Assets/Fonts/Sansation-Bold.ttf#Sansation"/>
                <ProgressBar Width="320"
                             Height="8"
                             IsIndeterminate="{Binding ScanProgressIsIndeterminate}"
                             Minimum="{Binding ScanProgressMinimum}"
                             Maximum="{Binding ScanProgressMaximum}"
                             Value="{Binding ScanProgressValue}"/>
            </StackPanel>

            <ProgressRing IsActive="{Binding IsAppSpinnerActive}"
                          Visibility="{Binding IsAppSpinnerActive, Converter={StaticResource BoolToVisibilityConverter}}"
                          Width="48"
                          Height="48"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>

            <Grid Visibility="{Binding IsDetailLoadingVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                  Background="{StaticResource BlurOverlayBrush}"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <ProgressRing Width="64" Height="64" IsActive="True"/>
                    <TextBlock Text="Loading game assets..." FontSize="16" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Onboarding overlay for first launch / empty library -->
        <Grid x:Name="OnboardingOverlay"
              Grid.RowSpan="2"
              Grid.ColumnSpan="2"
              Visibility="{Binding IsOnboardingVisible, Converter={StaticResource BoolToVisibilityConverter}}"
              Background="#FF1C1C1C"
              IsHitTestVisible="True">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="1100" Margin="0,0,32,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="48" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       Source="ms-appx:///Assets/shrimpStand.png"
                       Height="360"
                       Stretch="Uniform"/>

                <StackPanel Grid.Column="2" Spacing="12" VerticalAlignment="Center" MaxWidth="520">
                    <TextBlock Text="Welcome to Codec!" FontSize="28" FontWeight="Bold" FontFamily="ms-appx:///Assets/Fonts/Sansation-Bold.ttf#Sansation"/>
                    <TextBlock Text="I'm Shrimp, and I'd love to guide you through Codec."
                               FontSize="18"
                               TextWrapping="WrapWholeWords"
                               FontFamily="ms-appx:///Assets/Fonts/Sansation-Bold.ttf#Sansation"/>
                    <TextBlock Text="I'll try to find all your games for you, but you can always add any that I miss later on. If you'd rather skip that for now, you're free to use the button below."
                               FontSize="18"
                               TextWrapping="WrapWholeWords"
                               FontFamily="ms-appx:///Assets/Fonts/Sansation-Bold.ttf#Sansation"/>
                    <TextBlock Text="My goal is to make collecting games as easy and fun as possible—no matter where they came from. If something doesn't work right or you need a hand, you can reach out to my creator on GitHub."
                               FontSize="18"
                               TextWrapping="WrapWholeWords"
                               FontFamily="ms-appx:///Assets/Fonts/Sansation-Bold.ttf#Sansation"
                               Foreground="#FF868686"/>
                    <TextBlock Text="Thank you for giving Codec a try."
                               FontSize="18"
                               TextWrapping="WrapWholeWords"
                               FontFamily="ms-appx:///Assets/Fonts/Sansation-Bold.ttf#Sansation"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,0,0,0">
                        <Button Content="Start" FontWeight="SemiBold" Padding="24,8" Click="OnboardingStart_Click"/>
                        <Button Content="Skip" FontWeight="SemiBold" Padding="24,8" Click="OnboardingSkip_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Loading overlay for initial load or scanning -->
        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="2"
              Grid.ColumnSpan="2"
              Visibility="{Binding IsLoadingVisible, Converter={StaticResource BoolToVisibilityConverter}}"
              Background="#FF1C1C1C"
              IsHitTestVisible="True">
            <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,32,0">
                <Image Source="ms-appx:///Assets/shrimpRun.png"
                       Height="320"
                       Stretch="Uniform"/>
                <StackPanel Spacing="4" VerticalAlignment="Center" MaxWidth="460">
                    <TextBlock Text="{Binding LoadingTitle}"
                           FontSize="28"
                           TextWrapping="WrapWholeWords"
                           FontFamily="ms-appx:///Assets/Fonts/Sansation-Bold.ttf#Sansation"/>
                    <TextBlock Text="{Binding LoadingSubtitle}"
                           FontSize="18"
                           TextWrapping="WrapWholeWords"
                           FontFamily="ms-appx:///Assets/Fonts/Sansation-Bold.ttf#Sansation"
                           Foreground="#FF868686"/>
                    <ProgressBar Width="445"
                                 Height="8"
                                 CornerRadius="16"
                                 IsIndeterminate="True"
                                 Foreground="#FF5BDFFF"
                                 Background="#FF2A2A2A"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
