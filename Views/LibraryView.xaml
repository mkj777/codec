<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Codec.Views.LibraryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Codec.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer x:Name="LibraryScroller"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Padding="0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <ItemsRepeater x:Name="LibraryItemsRepeater"
                       Width="{x:Bind LibraryScroller.ViewportWidth, Mode=OneWay}"
                       ItemsSource="{Binding Games}"
                       HorizontalAlignment="Stretch">
            <ItemsRepeater.Layout>
                <UniformGridLayout x:Name="LibraryItemsLayout"
                                   MinItemWidth="210"
                                   MinItemHeight="315"
                                   MinColumnSpacing="12"
                                   MinRowSpacing="12"
                                   ItemsStretch="Uniform"/>
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
                <DataTemplate x:DataType="local:Game">
                    <Button Click="LibraryItem_Click"
                            ClickMode="Press"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Tag="{x:Bind}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            UseSystemFocusVisuals="False">
                        <Grid>
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="8">
                                <Image Source="{x:Bind LibCapsule}"
                                       Stretch="UniformToFill"/>
                            </Border>
                        </Grid>
                    </Button>
                </DataTemplate>
            </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>
    </ScrollViewer>

</UserControl>
