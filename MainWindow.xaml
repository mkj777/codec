<Window
    x:Class="Codec.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Codec.Models"
    xmlns:conv="using:Codec.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" MinWidth="420" MinHeight="520">
         <Grid.Resources>
             <conv:ListToCommaConverter x:Key="ListToCommaConverter" />
             <conv:SecondsToTimeConverter x:Key="SecondsToTimeConverter" />
             <conv:DateToStringConverter x:Key="DateToStringConverter" />
             <conv:PercentageConverter x:Key="PercentageConverter" />
             <conv:MediaTypeToVisibilityConverter x:Key="MediaTypeToVisibilityConverter" />
             <conv:MultiplyConverter x:Key="MultiplyConverter" />
             <conv:UriToMediaSourceConverter x:Key="UriToMediaSourceConverter" />
             <conv:NullOrEmptyToFallbackConverter x:Key="NullOrEmptyToFallbackConverter" />
             <conv:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
             <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <Style x:Key="UnderlinedHyperlinkButton" TargetType="HyperlinkButton">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="ContentTemplate">
                    <Setter.Value>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextDecorations="Underline" FontWeight="SemiBold" />
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
             <!-- Softer default blur overlay -->
            <AcrylicBrush x:Key="BlurOverlayBrush"
                          TintColor="#66000000"
                          TintOpacity="0.25"
                          TintLuminosityOpacity="0.8"
                          FallbackColor="#66000000" />
            <Style TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
        </Grid.Resources>
 
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
 
        <Grid Grid.Row="0" x:Name="AppTitleBar" Height="48" Visibility="Collapsed" />
 
        <!-- Main content with sidebar and library/details area -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
 
            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#1E1E1E" Padding="12" CornerRadius="12" Margin="12,6,0,12">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Vertical" Spacing="4">
                        <TextBlock Text="Codec Library" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="Your games" Opacity="0.6" FontSize="12" />
                    </StackPanel>
 
                    <ListView x:Name="SidebarGameList"
                              Grid.Row="1"
                              ItemsSource="{Binding Games}"
                              SelectionMode="Single"
                              SelectionChanged="SidebarGameList_SelectionChanged"
                              BorderThickness="0"
                              Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:Game">
                                <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
 
                    <StackPanel Grid.Row="2" Spacing="8">
                        <Button x:Name="SidebarDebugButton"
                                Content="Debug"
                                HorizontalAlignment="Stretch"
                                FontWeight="SemiBold">
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Scan for Games" Click="SidebarScan_Click" />
                                    <MenuFlyoutItem Text="Add Executable" Click="AddGame_Click" />
                                    <MenuFlyoutItem Text="Data" Click="Debug_Click" />
                                    <MenuFlyoutItem Text="Refresh Covers" Click="RefreshCovers_Click" />
                                    <MenuFlyoutItem Text="Reset App" Click="ResetApp_Click" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
 
                        <Grid Height="120">
                            <Image Source="Assets/shrimpSleep.png" Stretch="UniformToFill" Opacity="0.9" />
                            <Button x:Name="SidebarAddButton"
                                    Content="Add Games"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom"
                                    Margin="12"
                                    Padding="16,8"
                                    FontWeight="SemiBold"
                                    Click="SidebarAddGames_Click" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
 
            <!-- Library grid of cover images -->
            <Grid x:Name="LibraryGrid" Grid.Column="1" Margin="12,6,12,12">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Games, Mode=OneWay}"
                                   HorizontalAlignment="Stretch">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="270"
                                               MinItemHeight="405"
                                               MinColumnSpacing="12"
                                               MinRowSpacing="12"
                                               ItemsJustification="SpaceBetween"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="local:Game">
                                <Button Click="LibraryItem_Click"
                                        ClickMode="Press"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        Tag="{x:Bind}"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        UseSystemFocusVisuals="False">
                                    <Grid Width="270" Height="405">
                                        <Border CornerRadius="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                                        <Image Source="{x:Bind LibCapsule}" Stretch="UniformToFill"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
            </Grid>
 
            <!-- Game details full page -->
            <Grid x:Name="DetailsView"
                  Grid.Column="1"
                  Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>
 
                <!-- Hero covers upper half -->
                <Grid Grid.Row="0">
                    <Image Source="{Binding LibHero}" Stretch="UniformToFill"/>
                    <Grid Background="#4C000000" />
                    <Grid x:Name="HeroOverlay" Margin="20" VerticalAlignment="Stretch" SizeChanged="HeroOverlay_SizeChanged">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
 
                        <!-- Top controls and logo overlay -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
 
                            <!-- Back stays top-left -->
                            <Button x:Name="BackButton"
                                    Click="BackButton_Click"
                                    Content="←"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Left"
                                    FontWeight="SemiBold"/>

                            <!-- Logo overlayed with dynamic padding -->
                            <Grid>
                                <Image x:Name="HeroLogo"
                                    Source="{Binding LibLogo}"
                                    Height="300"
                                    MaxWidth="600"
                                    Stretch="Uniform"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    IsHitTestVisible="False"
                                    Margin="24,50,0,0"/>
                            </Grid>
                        </Grid>
 
                        <!-- Settings button bottom-right of the hero (top half) with tighter inset -->
                        <Button x:Name="DetailsSettingsButton"
                                Grid.RowSpan="3"
                                Content="Settings"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Margin="0,0,0,0"
                                FontWeight="SemiBold"/>

                        <!-- Play placeholder button anchored to the hero's lower-left corner -->
                        <Button x:Name="DetailsPlayButton"
                                Grid.Row="2"
                                Content="Play"
                                Padding="24,8"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Margin="0,0,0,0"
                                FontWeight="SemiBold"/>
                    </Grid>
                </Grid>
 
                <!-- Lower Half -->
                <Grid x:Name="DetailsLowerGrid" Grid.Row="1" Margin="20,20,0,20"
                        ColumnSpacing="24" SizeChanged="DetailsLowerGrid_SizeChanged">
                    <Grid.ColumnDefinitions>
                        <!-- Media carousel -->
                        <ColumnDefinition Width="2*" MinWidth="420"/>
                        <!-- Data + Description -->
                        <ColumnDefinition Width="3*" />
                        <!-- Links -->
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
 
                    <!-- Media carousel links -->
                    <StackPanel Grid.Column="0" Spacing="0">
                        <Grid x:Name="MediaContainer" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" SizeChanged="MediaContainer_SizeChanged">
                            <FlipView x:Name="MediaFlipView"
                                      ItemsSource="{Binding Media}"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top"
                                      HorizontalContentAlignment="Stretch"
                                      VerticalContentAlignment="Stretch">
                                <FlipView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <MediaPlayerElement AreTransportControlsEnabled="True"
                                                               Source="{Binding Converter={StaticResource UriToMediaSourceConverter}}"
                                                               AutoPlay="False"
                                                               Visibility="{Binding Converter={StaticResource MediaTypeToVisibilityConverter}, ConverterParameter=video}"/>
                                            <Image Source="{Binding}"
                                                   Stretch="UniformToFill"
                                                   Visibility="{Binding Converter={StaticResource MediaTypeToVisibilityConverter}, ConverterParameter=image}"/>
                                        </Grid>
                                    </DataTemplate>
                                </FlipView.ItemTemplate>
                            </FlipView>
                        </Grid>
                    </StackPanel>
 
                    <!-- Mitte: Game Info + Beschreibung -->
                    <ScrollViewer Grid.Column="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  HorizontalAlignment="Stretch">
                        <StackPanel Spacing="8" HorizontalAlignment="Stretch">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           TextWrapping="WrapWholeWords"
                                           VerticalAlignment="Center" />
                            <ItemsControl Grid.Column="1"
                                              ItemsSource="{Binding PlatformLogoUris, Mode=OneWay}"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Margin="0,0,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="10" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding}" Height="20" Stretch="Uniform" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            </Grid>
 
                            <!-- Game Info Block split into two columns -->
                            <Grid ColumnSpacing="24" HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="270"/>
                                    <ColumnDefinition Width="270"/>
                                </Grid.ColumnDefinitions>
 
                                <StackPanel Grid.Column="0" Spacing="12">
                                    <StackPanel Spacing="1">
                                        <TextBlock Text="Publisher" Opacity="0.4"/>
                                        <TextBlock Text="{Binding Path=Publisher, Converter={StaticResource NullOrEmptyToFallbackConverter}, FallbackValue='N/A'}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Spacing="1">
                                        <TextBlock Text="Developer" Opacity="0.4"/>
                                        <TextBlock Text="{Binding Path=Developer, Converter={StaticResource NullOrEmptyToFallbackConverter}, FallbackValue='N/A'}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Spacing="1">
                                        <TextBlock Text="Genre" Opacity="0.4"/>
                                        <TextBlock Text="{Binding Path=Genres, Converter={StaticResource ListToCommaConverter}, FallbackValue='N/A'}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Spacing="1">
                                        <TextBlock Text="Age Rating" Opacity="0.4"/>
                                        <TextBlock Text="{Binding Path=AgeRating, Converter={StaticResource NullOrEmptyToFallbackConverter}, ConverterParameter='Not Rated', FallbackValue='Not Rated'}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="1">
                                        <TextBlock Text="Release Date" Opacity="0.4"/>
                                        <TextBlock Text="{Binding Path=ReleaseDate, Converter={StaticResource DateToStringConverter}, FallbackValue='N/A'}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="1">
                                        <TextBlock Text="Price" Opacity="0.4"/>
                                        <TextBlock>
                                            <Run Text="{Binding Path=Price, Converter={StaticResource NullOrEmptyToFallbackConverter}, FallbackValue='N/A'}" />
                                            <Run Text="{Binding Path=PriceDiscount, FallbackValue=''}" FontSize="12" Foreground="#B3FFFFFF" />
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
 
                                <StackPanel Grid.Column="1" Spacing="12">
                                    <StackPanel Spacing="0"
                                            Visibility="{Binding SteamID, Converter={StaticResource NullToVisibilityConverter}}">
                                        <TextBlock Text="Steam Reviews" Opacity="0.4"/>
                                        <TextBlock>
                                            <Run Text="{Binding Path=SteamReviewSummary, Converter={StaticResource NullOrEmptyToFallbackConverter}, FallbackValue='N/A'}"/>
                                            <Run Text="(" FontSize="12" Foreground="Gray"/>
                                            <Run Text="{Binding Path=SteamReviewTotal, Converter={StaticResource NullOrEmptyToFallbackConverter}, FallbackValue='N/A'}" FontSize="12" Foreground="Gray"/>
                                            <Run Text=")" FontSize="12" Foreground="Gray"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Spacing="1"
                                            Visibility="{Binding TimeToCompleteMainStory, Converter={StaticResource NullToVisibilityConverter}}">
                                        <TextBlock Text="Main Story" Opacity="0.4"/>
                                        <TextBlock Text="{Binding Path=TimeToCompleteMainStory, Converter={StaticResource SecondsToTimeConverter}, FallbackValue='N/A'}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="1"
                                            Visibility="{Binding TimeToCompleteCompletionist, Converter={StaticResource NullToVisibilityConverter}}">
                                        <TextBlock Text="Completionist" Opacity="0.4"/>
                                        <TextBlock Text="{Binding Path=TimeToCompleteCompletionist, Converter={StaticResource SecondsToTimeConverter}, FallbackValue='N/A'}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="1">
                                        <TextBlock Text="Description" Opacity="0.4"/>
                                        <TextBlock Text="{Binding Path=Description, Converter={StaticResource NullOrEmptyToFallbackConverter}, FallbackValue='N/A'}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
 
                    <!-- Rechts: Links -->
                    <StackPanel Grid.Column="1"
                        Spacing="2"
                        Margin="0,38,0,0"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Right">
                            <HyperlinkButton Content="Official Website"
                                Foreground="White"
                                Style="{StaticResource UnderlinedHyperlinkButton}"
                                HorizontalAlignment="Right"
                                NavigateUri="{Binding OfficialWebsiteUrl}"
                                Visibility="{Binding OfficialWebsiteUrl, Converter={StaticResource NullToVisibilityConverter}}"/>
                            <HyperlinkButton Content="Steam"
                                Foreground="White"
                                Style="{StaticResource UnderlinedHyperlinkButton}"
                                HorizontalAlignment="Right"
                                NavigateUri="{Binding SteamPageUrl}"
                                Visibility="{Binding SteamPageUrl, Converter={StaticResource NullToVisibilityConverter}}"/>
                            <HyperlinkButton Content="RAWG"
                                Foreground="White"
                                Style="{StaticResource UnderlinedHyperlinkButton}"
                                HorizontalAlignment="Right"
                                NavigateUri="{Binding RawgUrl}"
                                Visibility="{Binding RawgUrl, Converter={StaticResource NullToVisibilityConverter}}"/>
                            <HyperlinkButton Content="HowLongToBeat"
                                Foreground="White"
                                Style="{StaticResource UnderlinedHyperlinkButton}"
                                HorizontalAlignment="Right"
                                NavigateUri="{Binding HltbUrl}"
                                Visibility="{Binding TimeToCompleteMainStory, Converter={StaticResource NullToVisibilityConverter}}"/>
                        </StackPanel>
                </Grid>
            </Grid>
        </Grid>
        <!-- Global app-level overlay -->
        <Grid Grid.RowSpan="2" Grid.ColumnSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="True">
            <StackPanel x:Name="ScanProgressPanel"
                        Visibility="Collapsed"
                        Background="#BF1C1C1C"
                        Padding="24"
                        CornerRadius="8"
                        Spacing="12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock x:Name="ScanProgressText"
                           Text="Durchsuche Bibliotheken..."
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           FontFamily="/Assets/Sansation-Bold.ttf#Sansation"/>
                <ProgressBar x:Name="ScanProgressBar"
                             Width="320"
                             Height="8"
                             IsIndeterminate="True"/>
            </StackPanel>
 
            <ProgressRing x:Name="AppSpinner"
                          IsActive="False"
                          Visibility="Collapsed"
                          Width="48"
                          Height="48"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
 
            <Grid x:Name="DetailLoadingOverlay"
                  Visibility="Collapsed"
                  Background="{StaticResource BlurOverlayBrush}"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <ProgressRing Width="64" Height="64" IsActive="True"/>
                    <TextBlock Text="Loading game assets..." FontSize="16" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
 
         <!-- Onboarding overlay for first launch / empty library -->
         <Grid x:Name="OnboardingOverlay"
               Grid.RowSpan="2"
               Grid.ColumnSpan="2"
                Visibility="{Binding IsOnboardingVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="#FF1C1C1C"
                IsHitTestVisible="True">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="1100" Margin="0,0,32,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="48" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
 
                <Image Grid.Column="0"
                       Source="Assets/shrimpStand.png"
                       Height="360"
                       Stretch="Uniform"/>
 
                <StackPanel Grid.Column="2" Spacing="12" VerticalAlignment="Center" MaxWidth="520">
                    <TextBlock Text="Welcome to Codec!" FontSize="28" FontWeight="Bold" FontFamily="/Assets/Sansation-Bold.ttf#Sansation"/>
                    <TextBlock Text="I'm Shrimp, and I'd love to guide you through Codec."
                               FontSize="18"
                               TextWrapping="WrapWholeWords"
                               FontFamily="/Assets/Sansation-Bold.ttf#Sansation"/>
                    <TextBlock Text="I'll try to find all your games for you, but you can always add any that I miss later on. If you'd rather skip that for now, you're free to use the button below."
                               FontSize="18"
                               TextWrapping="WrapWholeWords"
                               FontFamily="/Assets/Sansation-Bold.ttf#Sansation"/>
                    <TextBlock Text="My goal is to make collecting games as easy and fun as possible—no matter where they came from. If something doesn’t work right or you need a hand, you can reach out to my creator on GitHub."
                               FontSize="18"
                               TextWrapping="WrapWholeWords"
                               FontFamily="/Assets/Sansation-Bold.ttf#Sansation"
                               Foreground="#FF868686"/>
                    <TextBlock Text="Thank you for giving Codec a try."
                               FontSize="18"
                               TextWrapping="WrapWholeWords"
                               FontFamily="/Assets/Sansation-Bold.ttf#Sansation"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,0,0,0">
                        <Button Content="Start" FontWeight="SemiBold" Padding="24,8" Click="OnboardingStart_Click"/>
                        <Button Content="Skip" FontWeight="SemiBold" Padding="24,8" Click="OnboardingSkip_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
 
        <!-- Loading overlay for initial load or scanning -->
        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="2"
              Grid.ColumnSpan="2"
               Visibility="{Binding IsLoadingVisible, Converter={StaticResource BoolToVisibilityConverter}}"
               Background="#FF1C1C1C"
               IsHitTestVisible="True">
            <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,32,0">
                    <Image Source="Assets/shrimpRun.png"
                           Height="320"
                           Stretch="Uniform"/>
                    <StackPanel Spacing="4" VerticalAlignment="Center" MaxWidth="460">
                        <TextBlock Text="{Binding LoadingTitle}"
                               FontSize="28"
                               TextWrapping="WrapWholeWords"
                               FontFamily="/Assets/Sansation-Bold.ttf#Sansation"/>
                        <TextBlock Text="{Binding LoadingSubtitle}"
                               FontSize="18"
                               TextWrapping="WrapWholeWords"
                               FontFamily="/Assets/Sansation-Bold.ttf#Sansation"
                               Foreground="#FF868686"/>
                        <ProgressBar Width="450"
                                     Height="8"
                                     IsIndeterminate="True"
                                     Foreground="#FF5BDFFF"
                                     Background="#FF2A2A2A"/>
                    </StackPanel>
                </StackPanel>
        </Grid>
    </Grid>
</Window>