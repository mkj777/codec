<Window
    x:Class="Codec.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Codec.Models"
    xmlns:conv="using:Codec.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <conv:ListToCommaConverter x:Key="ListToCommaConverter" />
            <conv:SecondsToTimeConverter x:Key="SecondsToTimeConverter" />
            <conv:DateToStringConverter x:Key="DateToStringConverter" />
            <conv:PercentageConverter x:Key="PercentageConverter" />
            <conv:MediaTypeToVisibilityConverter x:Key="MediaTypeToVisibilityConverter" />
            <conv:MultiplyConverter x:Key="MultiplyConverter" />
            <conv:UriToMediaSourceConverter x:Key="UriToMediaSourceConverter" />
            <conv:NullOrEmptyToFallbackConverter x:Key="NullOrEmptyToFallbackConverter" />
            <!-- Softer default blur overlay -->
            <AcrylicBrush x:Key="BlurOverlayBrush"
                          TintColor="#66000000"
                          TintOpacity="0.25"
                          TintLuminosityOpacity="0.8"
                          FallbackColor="#66000000" />
            <Style TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" x:Name="AppTitleBar" Height="48">
            <TextBlock Text="Codec"
                       FontFamily="/Assets/Sansation-Bold.ttf#Sansation"
                       FontSize="18"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Margin="20,0"/>
        </Grid>

        <!-- Library grid of cover images -->
        <GridView x:Name="LibraryGrid"
              Grid.Row="1" Margin="30,5,30,5"
              ItemsSource="{x:Bind ViewModel.Games, Mode=OneWay}"
              IsItemClickEnabled="True"
              ItemClick="GameItem_Click"
              SelectionMode="None">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="local:Game">
                    <Grid Width="300" Height="450">
                        <Border CornerRadius="10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                        <Image Source="{x:Bind LibCapsule}" Stretch="UniformToFill"/>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <!-- Game details full page -->
        <Grid x:Name="DetailsView"
              Grid.RowSpan="3"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <!-- Hero covers upper half -->
            <Grid Grid.Row="0">
                <Image Source="{Binding LibHero}" Stretch="UniformToFill"/>
                <Grid Background="#4C000000" />
                <Grid x:Name="HeroOverlay" Margin="20" VerticalAlignment="Stretch" SizeChanged="HeroOverlay_SizeChanged">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Top controls and logo overlay -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Back stays top-left -->
                        <Button x:Name="BackButton"
                                Click="BackButton_Click"
                                Content="← Back"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Left"
                                FontWeight="SemiBold"/>

                        <!-- Settings button relocated below; reserved spot left empty here -->

                        <!-- Logo overlayed with dynamic padding -->
                           <Grid>
                            <Image x:Name="HeroLogo"
                                Source="{Binding LibLogo}"
                                Height="170"
                                MaxWidth="480"
                                Stretch="Uniform"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                IsHitTestVisible="False"
                                Margin="24,24,0,0"/>
                           </Grid>
                    </Grid>

                    <StackPanel Grid.Row="2" Spacing="6" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding Name}" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>

                        <!-- Settings button bottom-right of the hero (top half) with tighter inset -->
                        <Button x:Name="DetailsSettingsButton"
                            Grid.RowSpan="3"
                            Content="Settings"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0,0,8,8"
                            FontWeight="SemiBold"/>
                </Grid>
            </Grid>

            <!-- Lower Half -->
                        <Grid x:Name="DetailsLowerGrid" Grid.Row="1" Margin="20"
                    ColumnSpacing="24" SizeChanged="DetailsLowerGrid_SizeChanged">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" MinWidth="420"/>
                                    <!-- Screenshots -->
                                    <ColumnDefinition Width="2*" />
                                    <!-- Daten + Description -->
                                    <ColumnDefinition Width="*"/>
                                    <!-- Links -->
                                </Grid.ColumnDefinitions>

                    <!-- Media carousel links -->
                    <StackPanel Grid.Column="0" Spacing="0">
                        <Grid x:Name="MediaContainer" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" SizeChanged="MediaContainer_SizeChanged">
                            <FlipView x:Name="MediaFlipView"
                                      ItemsSource="{Binding Media}"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top"
                                      HorizontalContentAlignment="Stretch"
                                      VerticalContentAlignment="Stretch">
                                <FlipView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <MediaPlayerElement AreTransportControlsEnabled="True"
                                                               Source="{Binding Converter={StaticResource UriToMediaSourceConverter}}"
                                                               AutoPlay="False"
                                                               Visibility="{Binding Converter={StaticResource MediaTypeToVisibilityConverter}, ConverterParameter=video}"/>
                                            <Image Source="{Binding}"
                                                   Stretch="UniformToFill"
                                                   Visibility="{Binding Converter={StaticResource MediaTypeToVisibilityConverter}, ConverterParameter=image}"/>
                                        </Grid>
                                    </DataTemplate>
                                </FlipView.ItemTemplate>
                            </FlipView>
                        </Grid>
                    </StackPanel>

                    <!-- Mitte: Game Info + Beschreibung -->
                    <ScrollViewer Grid.Column="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  HorizontalAlignment="Left">
                        <StackPanel Spacing="16">
                        <!-- Game Info Block split into two columns -->
                        <Grid ColumnSpacing="24" MaxWidth="900" HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Publisher" Opacity="0.7"/>
                                    <TextBlock Text="{Binding Path=Publisher, Converter={StaticResource NullOrEmptyToFallbackConverter}, FallbackValue='N/A'}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Developer" Opacity="0.7"/>
                                    <TextBlock Text="{Binding Path=Developer, Converter={StaticResource NullOrEmptyToFallbackConverter}, FallbackValue='N/A'}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Genre" Opacity="0.7"/>
                                    <TextBlock Text="{Binding Path=Genres, Converter={StaticResource ListToCommaConverter}, FallbackValue='N/A'}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Age Rating" Opacity="0.7"/>
                                    <TextBlock Text="{Binding Path=AgeRating, Converter={StaticResource NullOrEmptyToFallbackConverter}, ConverterParameter='Not Rated', FallbackValue='Not Rated'}"/>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Release Date" Opacity="0.7"/>
                                    <TextBlock Text="{Binding Path=ReleaseDate, Converter={StaticResource DateToStringConverter}, FallbackValue='N/A'}"/>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Price" Opacity="0.7"/>
                                    <TextBlock>
                                        <Run Text="{Binding Path=Price, Converter={StaticResource NullOrEmptyToFallbackConverter}, FallbackValue='N/A'}" />
                                        <Run Text="{Binding Path=PriceDiscount, FallbackValue=''}" FontSize="12" Foreground="#B3FFFFFF" />
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="16">
                                <StackPanel Spacing="2"
                                            Visibility="{Binding SteamID, Converter={StaticResource NullToVisibilityConverter}}">
                                    <TextBlock Text="Steam Reviews" Opacity="0.7"/>
                                    <TextBlock>
                                        <Run Text="{Binding Path=SteamReviewSummary, Converter={StaticResource NullOrEmptyToFallbackConverter}, FallbackValue='N/A'}"/>
                                        <Run Text=" (" FontSize="12" Foreground="Gray"/>
                                        <Run Text="{Binding Path=SteamReviewTotal, Converter={StaticResource NullOrEmptyToFallbackConverter}, FallbackValue=''}" FontSize="12" Foreground="Gray"/>
                                        <Run Text=")" FontSize="12" Foreground="Gray"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Spacing="2"
                                            Visibility="{Binding TimeToCompleteMainStory, Converter={StaticResource NullToVisibilityConverter}}">
                                    <TextBlock Text="Main Story" Opacity="0.7"/>
                                    <TextBlock Text="{Binding Path=TimeToCompleteMainStory, Converter={StaticResource SecondsToTimeConverter}, FallbackValue='N/A'}"/>
                                </StackPanel>
                                <StackPanel Spacing="2"
                                            Visibility="{Binding TimeToCompleteCompletionist, Converter={StaticResource NullToVisibilityConverter}}">
                                    <TextBlock Text="Completionist" Opacity="0.7"/>
                                    <TextBlock Text="{Binding Path=TimeToCompleteCompletionist, Converter={StaticResource SecondsToTimeConverter}, FallbackValue='N/A'}"/>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Description" Opacity="0.7"/>
                                    <TextBlock Text="{Binding Path=Description, Converter={StaticResource NullOrEmptyToFallbackConverter}, FallbackValue='N/A'}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Rechts: Links -->
                    <StackPanel Grid.Column="2"
                    Spacing="8"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right">
                        <HyperlinkButton Content="Official Website"
                            HorizontalAlignment="Right"
                            NavigateUri="{Binding OfficialWebsiteUrl}"
                            Visibility="{Binding OfficialWebsiteUrl, Converter={StaticResource NullToVisibilityConverter}}"/>
                        <HyperlinkButton Content="Steam"
                            HorizontalAlignment="Right"
                            NavigateUri="{Binding SteamPageUrl}"
                            Visibility="{Binding SteamPageUrl, Converter={StaticResource NullToVisibilityConverter}}"/>
                        <HyperlinkButton Content="RAWG.io"
                            HorizontalAlignment="Right"
                            NavigateUri="{Binding RawgUrl}"
                            Visibility="{Binding RawgUrl, Converter={StaticResource NullToVisibilityConverter}}"/>
                        <HyperlinkButton Content="HowLongToBeat"
                            HorizontalAlignment="Right"
                            NavigateUri="{Binding HltbUrl}"
                            Visibility="{Binding TimeToCompleteMainStory, Converter={StaticResource NullToVisibilityConverter}}"/>
                    </StackPanel>
                </Grid>
        </Grid>

        <!-- Global app-level overlay -->
        <Grid Grid.RowSpan="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="True">
            <StackPanel x:Name="ScanProgressPanel"
                        Visibility="Collapsed"
                        Background="#BF1C1C1C"
                        Padding="24"
                        CornerRadius="8"
                        Spacing="12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock x:Name="ScanProgressText"
                           Text="Durchsuche Bibliotheken..."
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextAlignment="Center"/>
                <ProgressBar x:Name="ScanProgressBar"
                             Width="320"
                             Height="8"
                             IsIndeterminate="True"/>
            </StackPanel>

            <ProgressRing x:Name="AppSpinner"
                          IsActive="False"
                          Visibility="Collapsed"
                          Width="48"
                          Height="48"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>

            <Grid x:Name="DetailLoadingOverlay"
                  Visibility="Collapsed"
                  Background="{StaticResource BlurOverlayBrush}"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <ProgressRing Width="64" Height="64" IsActive="True"/>
                    <TextBlock Text="Loading game assets..." FontSize="16" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Bottom Bar with primary actions -->
        <Grid x:Name="BottomBar" Grid.Row="2" Height="70" Padding="20">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button x:Name="ScanGamesButton"
                        Content="Scan for Games"
                        Click="ScanGames_Click"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        UseSystemFocusVisuals="False"
                        FontSize="14"/>
                <Button x:Name="TestExecutableButton"
                        Content="Test Executable"
                        Click="AddGame_Click"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        UseSystemFocusVisuals="False"
                        FontSize="14"/>
                <Button x:Name="DebugButton"
                        Content="Debug"
                        Click="Debug_Click"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        UseSystemFocusVisuals="False"
                        FontSize="14"/>
                <Button x:Name="RefreshCoversButton"
                        Content="Refresh Covers"
                        Click="RefreshCovers_Click"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        UseSystemFocusVisuals="False"
                        FontSize="14"/>
                <Button x:Name="ResetAppButton"
                        Content="Reset App"
                        Click="ResetApp_Click"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        UseSystemFocusVisuals="False"
                        FontSize="14"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
















